# ============================================================
# ServeFlow – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# Die Defaults funktionieren für lokale Entwicklung mit
# docker/docker-compose.dev.yml.
# NIEMALS eine .env mit echten Secrets committen.
# ============================================================

# --- Allgemein ---------------------------------------------
# Öffentliche Basis-URL der Installation (für Links in E-Mails, iCal, CORS)
APP_URL=http://localhost:5173
# Port der API (hinter dem Reverse Proxy)
API_PORT=3000
# Default-Sprache der Instanz: de | en
DEFAULT_LOCALE=de

# --- Datenbank / Redis -------------------------------------
DATABASE_URL=postgresql://serveflow:serveflow@localhost:5432/serveflow
REDIS_URL=redis://localhost:6379

# --- Security ----------------------------------------------
# 32-Byte-Key (base64) für die AES-256-GCM-Verschlüsselung sensibler Felder (Notizen).
# Erzeugen mit:  openssl rand -base64 32
# ACHTUNG: Bei Verlust sind verschlüsselte Notizen unwiederbringlich verloren –
# Key ins (verschlüsselte) Backup aufnehmen.
FIELD_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32
# Cookie-Secret zum Signieren (openssl rand -base64 32)
COOKIE_SECRET=CHANGE_ME_openssl_rand_base64_32
# Session-Lebensdauer in Stunden
SESSION_TTL_HOURS=336

# --- SMTP (E-Mail-Benachrichtigungen) ----------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Absenderadresse aller System-Mails
SMTP_FROM="ServeFlow <noreply@example.org>"

# --- Erst-Einrichtung --------------------------------------
# Legt beim ersten Start EIN Admin-Konto an, falls noch keines existiert.
# Nach dem ersten Login wieder entfernen.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Erinnerungen ------------------------------------------
# Kommagetrennte Tage vor dem Termin, an denen erinnert wird
REMINDER_DAYS_BEFORE=7,1

# --- Produktion (docker/docker-compose.yml) ----------------
# Domain für Caddy (automatisches Let's-Encrypt-TLS)
DOMAIN=serveflow.example.org
# Postgres-Zugang im Compose-Stack
POSTGRES_USER=serveflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=serveflow
