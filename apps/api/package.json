{
  "name": "@serveflow/api",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "ServeFlow REST-API (NestJS + Fastify + Prisma)",
  "scripts": {
    "dev": "tsc-watch -p tsconfig.build.json --noClear --onSuccess \"node dist/main.js\"",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src prisma test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^10.1.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "@serveflow/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.8.1",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsc-watch": "^7.2.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
