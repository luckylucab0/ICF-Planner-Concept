{
  "name": "@serveflow/api",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "ServeFlow REST-API (NestJS + Fastify + Prisma)",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src prisma test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/swagger": "^11.1.5",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.7.0",
    "@serveflow/shared": "workspace:*",
    "argon2": "^0.41.1",
    "bullmq": "^5.49.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.6.1",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "prisma": "^6.7.0",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
